# Create a Hospital Class

class Hospital:
    def __init__(self, hospital_name, doctor_count, city):
        self.hospital_name = hospital_name
        self.doctor_count = doctor_count
        self.city = city

    def display(self):
        print("Hospital Name:", self.hospital_name)
        print("Doctor Count:", self.doctor_count)
        print("City:", self.city)


# Creating an object
h1 = Hospital("Apollo Hospital", 150, "Bhubaneswar")

# Displaying details
h1.display()